# Neon Postgres connection string (get this from https://console.neon.tech)
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/kitchenarykart?sslmode=require"

# JWT secret — generate with: openssl rand -base64 32
JWT_SECRET="replace-this-with-a-random-32-byte-secret"

# Seed credentials (first admin user created by `npm run db:seed`)
SEED_ADMIN_EMAIL="admin@kitchenarykart.com"
SEED_ADMIN_PASSWORD="admin123"

# ---- Optional integrations (stubs work without these) ----

# Razorpay (payments)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Twilio WhatsApp (order-status notifications)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
TWILIO_WHATSAPP_ADMIN="whatsapp:+919890352455"

# SMTP (email notifications)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="KitchenaryKart <no-reply@kitchenarykart.com>"

# Public site origin (for CORS + emails)
PUBLIC_SITE_URL="http://localhost:5500"
